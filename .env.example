# Required secrets — must be set before running
# SITE_NAME=<exactly two words, e.g. "Send Sats">

# 1 = first word orange, 2 = second word orange
# SITE_NAME_ORANGE_WORD=1

# BASE_URL=https://yourdomain.com
# MNEMONIC="<your 12-24 word BIP39 mnemonic here>"
# BREEZ_API_KEY="<your breez api key here>"
# ADMIN_TOKEN="<long random token to access admin>"

# Server
PORT=8080
NETWORK=mainnet
STORAGE_DIRECTORY=./.data
GITHUB_URL="https://github.com/witsand/satoshi-note"

# Backend bitcoin send and receive flags
CREATE_ACTIVE=true
FUND_ACTIVE=true
REDEEM_ACTIVE=true
REFUND_ACTIVE=true
REFUND_WORKER_INTERVAL_SECONDS=14400
PAYMENT_COOLDOWN_MS=200

# Frontend feature flags
BATCH_ENABLED=false
DEFAULT_DIAL_CODE=+27

# Invoice
INVOICE_EXPIRY_SECONDS=300

# Fee for redemptions
REDEEM_FEE_BPS=50
MIN_REDEEM_FEE_MSAT=10000

# Fee for internal transfers (voucher-to-voucher/donate)
INTERNAL_FEE_BPS=5
MIN_INTERNAL_FEE_MSAT=1000

# Voucher funding limits
MIN_FUND_AMOUNT_MSAT=11000
MAX_FUND_AMOUNT_MSAT=1000000000
MIN_REDEEM_AMOUNT_MSAT=1000
MAX_VOUCHER_EXPIRE_SECONDS=31556952

# Voucher creation
RANDOM_BYTES_LENGTH=32
MAX_VOUCHERS_PER_BATCH=32

