# BASE_URL=https://yourdomain.com
# MNEMONIC="<your 12-24 word BIP39 mnemonic here>"
# BREEZ_API_KEY="<your breez api key here>"

# Server
PORT=8080
NETWORK=mainnet
STORAGE_DIRECTORY=./.data

# Backend bitcoin send and receive flags
CREATE_ACTIVE=true
FUND_ACTIVE=true
REDEEM_ACTIVE=true
REFUND_ACTIVE=true
REFUND_WORKER_INTERVAL_SECONDS=14400
PAYMENT_COOLDOWN_MS=200

# Invoice
INVOICE_EXPIRY_SECONDS=300

# Fee for redemptions
REDEEM_FEE_BPS=50
MIN_REDEEM_FEE_MSAT=10000

# Fee for internal transfers (voucher-to-voucher/donate)
INTERNAL_FEE_BPS=5
MIN_INTERNAL_FEE_MSAT=1000

# Voucher funding limits
MIN_FUND_AMOUNT_MSAT=110000
MAX_FUND_AMOUNT_MSAT=1000000000
MIN_REDEEM_AMOUNT_MSAT=100000
MAX_VOUCHER_EXPIRE_SECONDS=2592000

# Voucher creation
RANDOM_BYTES_LENGTH=32
MAX_VOUCHERS_PER_BATCH=32

